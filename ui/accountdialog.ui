   <string notr="true">QDialog {
    background-color: #f5f5f5;
}
QLabel {
    font-size: 13px;
    color: #333333;
    font-weight: bold;
}
QLineEdit, QComboBox {
    padding: 8px;
    border: 1px solid #cccccc;
    border-radius: 4px;
    background-color: white;
    font-size: 13px;
    min-height: 35px;
}
QLineEdit:focus, QComboBox:focus {
    border: 2px solid #4a90d9;
}
QPushButton {
    padding: 8px 12px;
    border: none;
    border-radius: 4px;
    font-size: 13px;
    font-weight: bold;
    min-width: 60px;
}
QPushButton#showPasswordBtn, QPushButton#showConfirmPasswordBtn {
    background-color: #e0e0e0;
    color: #333333;
}
QPushButton#showPasswordBtn:hover, QPushButton#showConfirmPasswordBtn:hover {
    background-color: #d0d0d0;
}
QPushButton[text="确定"], QPushButton[text="OK"] {
    background-color: #4a90d9;
    color: white;
}
QPushButton[text="确定"]:hover, QPushButton[text="OK"]:hover {
    background-color: #3a7bc8;
}
QPushButton[text="取消"], QPushButton[text="Cancel"] {
    background-color: #e0e0e0;
    color: #333333;
}
QPushButton[text="取消"]:hover, QPushButton[text="Cancel"]:hover {
    background-color: #d0d0d0;
}</string>
