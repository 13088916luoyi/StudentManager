    background-color: #5bc0de;
    color: white;
    padding: 6px 12px;
    font-size: 11px;
    min-width: 60px;
}
QPushButton#selectAllButton:hover, QPushButton#deselectAllButton:hover {
    background-color: #46b8da;
}</string>
